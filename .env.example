# ── NextAuth ──────────────────────────────────────────────────────────────────
AUTH_SECRET=
AUTH_ORIGIN=http://localhost:3000

# ── Keycloak OIDC ─────────────────────────────────────────────────────────────
KEYCLOAK_ISSUER=https://keycloak.example.com/realms/emc
KEYCLOAK_CLIENT_ID=emc-app
KEYCLOAK_CLIENT_SECRET=

# ── Backend API (Nuxt server itself) ──────────────────────────────────────────
NUXT_PUBLIC_API_BASE_URL=https://api.example.com

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=
